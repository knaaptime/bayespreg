@book{anselin1988SpatialEconometrics,
  title = {Spatial {{Econometrics}}: {{Methods}} and {{Models}}},
  author = {Anselin, Luc},
  year = {1988},
  journaltitle = {Operational Regional Science Series},
  volume = {4},
  eprint = {1011.1669v3},
  eprinttype = {arXiv},
  publisher = {Springer Netherlands},
  location = {Dordrecht},
  issn = {00130095},
  doi = {10.1007/978-94-015-7799-1},
  url = {
         http://www.amazon.com/Spatial-Econometrics-Methods-Operational-Regional/dp/9024737354
         },
  abstract = {Graduate-level textbook in spatial statistics, econometrics, and
              regional analysis concentrates on the relevance of spatial effects
              to general issues of model specification, estimation, and other
              inference, taking a model-driven rather than a data-driven
              approach. Includes new methods and findings, and many new empirical
              examples. Introduces the formal probabilistic framework for the
              analysis of spatial processes. Covers estimation and hypothesis
              testing, discussing situations where the data are characterized by
              spatial dependence, the data are characterized by spatial
              heterogeneity, and where a time-space model is used. Outlines
              methodological problems arising in estimation and hypothesis
              testing. Provides an extensive empirical illustration for the
              various estimators and tests. Examines issues of model validation,
              discussing two types of specification tests: tests on spatial
              common factors and tests on non-nested hypotheses. Discusses model
              selection in spatial econometric models. Suggests directions for
              future research. Anselin is with the Department of Geography and
              Economics at the University of California, Santa Barbara. Index.},
  isbn = {978-90-481-8311-1},
  pagetotal = {289},
  pmid = {25246403},
  keywords = {neighborhoods,spatial-analysis},
}

