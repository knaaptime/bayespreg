@article{meng1996SimulatingRatios,
  title = {Simulating {{Ratios}} of {{Normalizing Constants Via}} a {{Simple
           Identity}}: {{A Theoretical Exploration}}},
  shorttitle = {Simulating {{Ratios}} of {{Normalizing Constants Via}} a {{
                Simple Identity}}},
  author = {Meng, Xiao-Li and Wong, Wing Hung},
  year = 1996,
  journal = {Statistica Sinica},
  volume = {6},
  number = {4},
  eprint = {24306045},
  eprinttype = {jstor},
  pages = {831--860},
  publisher = {Institute of Statistical Science, Academia Sinica},
  issn = {1017-0405},
  url = {https://www.jstor.org/stable/24306045},
  urldate = {2026-04-25},
  abstract = {Let pi(w),i = 1,2, be two densities with common support where each
              density is known up to a normalizing constant: pi(w) = qi(w)/ci. We
              have draws from each density (e.g., via Markov chain Monte Carlo),
              and we want to use these draws to simulate the ratio of the
              normalizing constants, c1/c2. Such a computational problem is often
              encountered in likelihood and Bayesian inference, and arises in
              fields such as physics and genetics. Many methods proposed in
              statistical and other literature (e.g., computational physics) for
              dealing with this problem are based on various special cases of the
              following simple identity: \$\textbackslash frac\textbraceleft c\_
              \textbraceleft 1\textbraceright\textbraceright\textbraceleft c\_
              \textbraceleft 2\textbraceright\textbraceright{} = \textbackslash
              frac\textbraceleft E\_\textbraceleft 2\textbraceright [q\_
              \textbraceleft 1\textbraceright (w)\textbackslash alpha (w)]
              \textbraceright\textbraceleft E\_\textbraceleft 1\textbraceright [q
              \_\textbraceleft 2\textbraceright (w)\textbackslash alpha (w)]
              \textbraceright\$ Here Ei denotes the expectation with respect to
              pi (i = 1,2), and {$\alpha$} is an arbitrary function such that the
              denominator is non-zero. A main purpose of this paper is to provide
              a theoretical study of the usefulness of this identity, with focus
              on (asymptotically) optimal and practical choices of {$\alpha$}.
              Using a simple but informative example, we demonstrate that with
              sensible (not necessarily optimal) choices of {$\alpha$}, we can
              reduce the simulation error by orders of magnitude when compared to
              the conventional importance sampling method, which corresponds to {
              $\alpha$} = 1/q2. We also introduce several generalizations of this
              identity for handling more complicated settings (e.g., estimating
              several ratios simultaneously) and pose several open problems that
              appear to have practical as well as theoretical value. Furthermore,
              we discuss related theoretical and empirical work.},
}

